MCP_PORT=8814
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=financecentre
# comma-separated: <keyName>:<key>=<scope>[+<scope>]   scopes: read, write
MCP_API_KEYS=agent1:CHANGE_ME_LONG_RANDOM=read
MCP_AUTH_DISABLED=false
LOG_LEVEL=info

# --- OAuth 2.1 (optional: aktiviert claude.ai Custom Connector Support) ---
# Public issuer URL (must match the reverse-proxy domain)
MCP_PUBLIC_URL=https://mcp.finanz-copilot.de
# Enables OAuth endpoints when set. Generate: openssl rand -hex 32
MCP_JWT_SECRET=
# MongoDB database for OAuth artifacts (clients, codes, refresh tokens)
MONGODB_AUTH_DB=mcp-fc
